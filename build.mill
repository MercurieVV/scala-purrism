//| mvnDeps:
//|   - com.github.lolgab::mill-mima::0.2.2

import mill.*
import scalalib.*
import javalib.*
import mill.javalib.publish.*
import mill.util.VcsVersionModule
import com.github.lolgab.mill.mima.*

object Versions {
  def scala3 = "3.8.4"
  def catsCore = "2.13.0"
  def catsEffect = "3.7.0"
  def mdoc = "2.9.1"
  def munit = "1.3.4"
  def munitScalaCheck = "1.3.0"
  def scalafix = "0.14.7"
  def scalaSemantic = "0.4.2"
}

object Project {
  def organization = "io.github.mercurievv"
  def repositoryOwner = "MercurieVV"
  def repositoryName = "scala-purrism"
}

object scalafix
    extends ScalaModule
    with SonatypeCentralPublishModule
    with VcsVersionModule
    with Mima {
  def scalaVersion = Versions.scala3
  def artifactName = "scala-purrism-scalafix"
  def mimaPreviousVersions = Seq("0.5.0")
  def pomSettings = PomSettings(
    description =
      "Scalafix semantic rules for refactoring Typelevel Scala code toward pure, polymorphic Cats and Cats Effect style.",
    organization = Project.organization,
    url = s"https://github.com/${Project.repositoryOwner}/${Project.repositoryName}",
    licenses = Seq(License.`Apache-2.0`),
    versionControl =
      VersionControl.github(Project.repositoryOwner, Project.repositoryName),
    developers = Seq(
      Developer(
        id = "MercurieVV",
        name = "MercurieVV",
        url = "https://github.com/MercurieVV"
      )
    )
  )

  def scalacOptions = Seq(
    "-Ysemanticdb",
    "-Wunused:imports",
    "-Werror"
  )
  def mvnDeps = Seq(
    // [dependencies-start]
    mvn"ch.epfl.scala:scalafix-rules_${Versions.scala3}:${Versions.scalafix}",
    mvn"io.github.mercurievv::scalasemantic-analysis:${Versions.scalaSemantic}",
    mvn"org.typelevel::cats-core:${Versions.catsCore}",
    mvn"org.typelevel::cats-effect:${Versions.catsEffect}"
    // [dependencies-end]
  )

  // Stainless is not a resolvable scalac-plugin Maven coordinate (verified: no
  // ch.epfl.lara:stainless-* artifact is published to Maven Central under any
  // version/name). Other projects run it as a standalone CLI over an
  // unmanaged stainless-library.jar instead of a compiler plugin dependency.
  def scalacPluginMvnDeps = Seq()

  // Fixture sources for scalafix-testkit. Compiled with SemanticDB so the
  // testkit can find a payload for each input file. Deliberately does NOT
  // inherit the main module's -Werror: fixtures contain the very code smells
  // the rules exist to remove.
  object testInput extends ScalaModule {
    def scalaVersion = Versions.scala3
    // -sourceroot must match the `sourceroot` property written below, or the
    // testkit looks for SemanticDB payloads under the wrong relative path.
    def scalacOptions =
      Seq("-Ysemanticdb", s"-sourceroot:${mill.api.BuildCtx.workspaceRoot}")
    def mvnDeps = Seq(
      mvn"org.typelevel::cats-core:${Versions.catsCore}",
      mvn"org.typelevel::cats-effect:${Versions.catsEffect}"
    )
  }

  // Expected output for each testInput fixture. Must compile, but needs no
  // SemanticDB.
  object testOutput extends ScalaModule {
    def scalaVersion = Versions.scala3
    def mvnDeps = testInput.mvnDeps
  }

  // Exploratory driver: ranks opaque-type candidates in an already-compiled
  // target codebase and applies `PropagateOpaqueType` to the top ones.
  //
  // Kept out of the published module on purpose -- it needs scalafix-cli to
  // run the rule, and a rule artifact that dragged the CLI in as a transitive
  // dependency would be unusable as a `scalafixDependencies` entry.
  //
  //   mill scalafix.explorer.runMain fix.opaque.ExploreOpaques \
  //     --target /path/to/gh-tasks-llm-executor
  object explorer extends ScalaModule {
    def scalaVersion = Versions.scala3
    def moduleDeps = Seq(scalafix)
    def mvnDeps = Seq(
      mvn"ch.epfl.scala:scalafix-cli_${Versions.scala3}:${Versions.scalafix}"
    )
  }

  // Tooling-only generator for the checked-in Cats capability inventory.
  // Kept out of the published module: TASTy inspection is a build-time concern.
  object indexgen extends ScalaModule {
    def scalaVersion = Versions.scala3
    def moduleDeps = Seq(scalafix)
    def mvnDeps = Seq(
      mvn"org.scala-lang:scala3-tasty-inspector_3:${Versions.scala3}",
      mvn"org.typelevel::scalac-compat-annotation:0.1.4"
    )
  }

  private def runCatsIndex(
      output: os.Path,
      classpath: Seq[os.Path]
  ): Unit = {
    def requiredJar(fileName: String): os.Path =
      classpath
        .find(_.last == fileName)
        .getOrElse(
          throw new RuntimeException(
            s"required Cats index input is missing from the resolved classpath: $fileName"
          )
        )

    val generatorArgs = Seq(
      "--output",
      output.toString,
      "--jar",
      requiredJar(s"cats-core_3-${Versions.catsCore}.jar").toString,
      "--jar",
      requiredJar(s"cats-kernel_3-${Versions.catsCore}.jar").toString
    )
    val javaExecutable =
      os.Path(sys.props("java.home")) / "bin" / "java"
    val command =
      Seq(
        javaExecutable.toString,
        "-cp",
        classpath.mkString(java.io.File.pathSeparator),
        "fix.hkt.gen.CatsIndexGen"
      ) ++ generatorArgs
    os.proc(command).call(
      cwd = mill.api.BuildCtx.workspaceRoot,
      stdout = os.Inherit,
      stderr = os.Inherit
    )
  }

  /** Regenerate the checked-in Cats capability inventory in place. */
  def catsIndex() = Task.Command {
    val output =
      mill.api.BuildCtx.workspaceRoot / "scalafix" / "resources" / "cats-index"
    runCatsIndex(output, indexgen.runClasspath().map(_.path))
  }

  /** Fail when generated Cats inventory files differ from their checked-in bytes. */
  def catsIndexCheck() = Task.Command {
    val generated = Task.dest / "cats-index"
    runCatsIndex(generated, indexgen.runClasspath().map(_.path))

    val checkedIn =
      mill.api.BuildCtx.workspaceRoot / "scalafix" / "resources" / "cats-index"
    Seq("typeclasses.tsv", "capabilities.tsv", "syntax.tsv").foreach { fileName =>
      val expected = checkedIn / fileName
      val actual = generated / fileName
      val identical =
        os.exists(expected) &&
          os.exists(actual) &&
          java.util.Arrays.equals(os.read.bytes(expected), os.read.bytes(actual))
      if (!identical)
        throw new RuntimeException(
          s"Cats index drift in $fileName; run: rtk mill scalafix.catsIndex"
        )
    }
  }

  object test extends ScalaTests {
    def testFramework = "munit.Framework"
    def mvnDeps = Seq(
      // [test-dependencies-start]
      mvn"ch.epfl.scala:scalafix-testkit_${Versions.scala3}:${Versions.scalafix}",
      mvn"org.scalameta::munit:${Versions.munit}",
      mvn"org.scalameta::munit-scalacheck:${Versions.munitScalaCheck}"
      // [test-dependencies-end]
    )

    def testkitProperties = Task {
      val sep = java.io.File.pathSeparator
      val lines = Seq(
        "inputClasspath" -> (testInput.compile().classes.path +: testInput
          .runClasspath()
          .map(_.path)).mkString(sep),
        "inputSourceDirectories" -> testInput
          .sources()
          .map(_.path)
          .mkString(sep),
        "outputSourceDirectories" -> testOutput
          .sources()
          .map(_.path)
          .mkString(sep),
        "sourceroot" -> mill.api.BuildCtx.workspaceRoot.toString,
        "scalaVersion" -> Versions.scala3,
        "scalacOptions" -> testInput.scalacOptions().mkString("|")
      ).map { case (key, value) => s"$key=$value" }
      os.write(
        Task.dest / "scalafix-testkit.properties",
        lines.mkString("\n")
      )
      Seq(PathRef(Task.dest))
    }

    def resources = Task { super.resources() ++ testkitProperties() }
  }
}

object docs extends ScalaModule {
  def scalaVersion = "3.3.8"
  def mvnDeps = Seq(mvn"org.scalameta::mdoc:${Versions.mdoc}")
}

def prePush() = Task.Command {
  scalafix.catsIndexCheck()()
  scalafix.compile()
  scalafix.explorer.compile()
  // Compile fixtures before the suite so a broken fixture reports as a compile
  // error rather than an opaque "SemanticDB not found" test failure.
  scalafix.testInput.compile()
  scalafix.testOutput.compile()
  scalafix.test.testForked()()
}
